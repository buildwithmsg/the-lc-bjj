---
import Layout from '@/components/Layout.astro';
import ProgramDetail from '@/components/ProgramDetail.astro';
import { programs } from '@/data/programs';
import { getCoach, type Coach } from '@/data/coaches';

export async function getStaticPaths() {
  return programs.map((program) => ({
    params: { slug: program.slug },
    props: { program },
  }));
}

const { program } = Astro.props;

const photos = import.meta.glob<{ default: ImageMetadata }>('@/assets/photos/*.jpg', { eager: true });
function resolvePhoto(filename: string, label: string): ImageMetadata {
  const entry = Object.entries(photos).find(([k]) => k.endsWith('/' + filename));
  if (!entry) throw new Error(`Missing ${label}: ${filename}`);
  return entry[1].default;
}

const heroPhoto = resolvePhoto(program.heroPhotoFile, 'hero photo');

const coachSlugs = [program.coachSlug, ...(program.assistCoachSlugs ?? [])];
const coachesWithPhotos: { coach: Coach; photo: ImageMetadata }[] = coachSlugs.map((slug) => {
  const coach = getCoach(slug);
  if (!coach) throw new Error(`Missing coach: ${slug}`);
  return { coach, photo: resolvePhoto(coach.photoFile, 'coach photo') };
});
---

<Layout title={program.metaTitle} description={program.metaDescription} canonicalPath={`/${program.slug}`}>
  <ProgramDetail program={program} heroPhoto={heroPhoto} coaches={coachesWithPhotos} />
</Layout>
