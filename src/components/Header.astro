---
import { Image } from 'astro:assets';
import logo from '@/assets/brand/the-lc-logo.png';
import { programs } from '@/data/programs';

interface Props { ctaHref?: string }
const { ctaHref = '/#schedule' } = Astro.props;
---

<header class="bg-iron text-paper border-b border-paper/10 relative">
  <div class="container-page flex items-center justify-between gap-4 py-3">
    <a href="/" class="flex items-center">
      <Image src={logo} alt="The LC logo" width={160} height={160} class="w-16 h-16 md:w-20 md:h-20 rounded-sm" />
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-semibold">
      <a href="/" class="hover:text-blood">Home</a>
      <details class="relative group">
        <summary class="cursor-pointer list-none hover:text-blood select-none">Programs ▾</summary>
        <div class="absolute right-0 mt-2 w-56 bg-iron border border-paper/15 rounded-md shadow-lg p-2 z-10">
          {programs.map((p) => (
            <a href={`/${p.slug}`} class="block px-3 py-2 rounded hover:bg-blood/20 hover:text-paper">{p.shortName}</a>
          ))}
        </div>
      </details>
      <a href="/#coaches" class="hover:text-blood">Coaches</a>
      <a href="/#visit" class="hover:text-blood">Visit</a>
    </nav>

    <div class="flex items-center gap-3">
      <a href={ctaHref} class="btn-primary text-xs sm:text-sm">First class is FREE →</a>
      <details class="md:hidden relative">
        <summary class="cursor-pointer list-none px-2 py-2 -mr-2 select-none" aria-label="Open menu">
          <span class="block w-5 h-0.5 bg-paper mb-1.5"></span>
          <span class="block w-5 h-0.5 bg-paper mb-1.5"></span>
          <span class="block w-5 h-0.5 bg-paper"></span>
        </summary>
        <div class="absolute right-0 top-full mt-2 w-64 bg-iron border border-paper/15 rounded-md shadow-lg p-2 z-20">
          <a href="/" class="block px-3 py-2 rounded hover:bg-blood/20 font-semibold">Home</a>
          <p class="px-3 pt-3 pb-1 text-[11px] uppercase tracking-eyebrow text-blood font-bold">Programs</p>
          {programs.map((p) => (
            <a href={`/${p.slug}`} class="block px-3 py-2 rounded hover:bg-blood/20">{p.shortName}</a>
          ))}
          <a href="/#coaches" class="block px-3 py-2 rounded hover:bg-blood/20 font-semibold mt-2 border-t border-paper/15 pt-3">Coaches</a>
          <a href="/#visit" class="block px-3 py-2 rounded hover:bg-blood/20 font-semibold">Visit</a>
        </div>
      </details>
    </div>
  </div>

  <script>
    // Close any header <details> dropdowns on Escape or click outside.
    const headerDetails = Array.from(document.querySelectorAll('header details'));
    document.addEventListener('click', (e) => {
      for (const d of headerDetails) {
        if (d instanceof HTMLDetailsElement && !d.contains(e.target as Node)) d.open = false;
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      for (const d of headerDetails) {
        if (d instanceof HTMLDetailsElement) d.open = false;
      }
    });
  </script>
</header>
