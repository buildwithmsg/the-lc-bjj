---
import { Image } from 'astro:assets';
import logo from '@/assets/brand/the-lc-logo.png';
import { programs } from '@/data/programs';

interface Props { ctaHref?: string }
const { ctaHref = '/#schedule' } = Astro.props;
---

<header class="bg-bone border-b border-iron/10">
  <div class="container-page flex items-center justify-between gap-4 py-4">
    <a href="/" class="flex items-center gap-3">
      <Image src={logo} alt="The LC logo" width={48} height={48} class="rounded-sm" />
      <span class="font-display text-2xl tracking-wide leading-none">The LC</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-semibold">
      <a href="/" class="hover:text-blood">Home</a>
      <div class="relative" id="programs-menu">
        <button
          type="button"
          aria-haspopup="true"
          aria-expanded="false"
          class="cursor-pointer hover:text-blood select-none"
          id="programs-menu-btn"
        >Programs ▾</button>
        <div
          id="programs-dropdown"
          class="absolute right-0 mt-2 w-56 bg-paper border border-iron/10 rounded-md shadow-lg p-2 z-10 hidden"
          role="menu"
        ></div>
      </div>
      <a href="/#coaches" class="hover:text-blood">Coaches</a>
      <a href="/#visit" class="hover:text-blood">Visit</a>
    </nav>

    <script define:vars={{ programs }}>
      const btn = document.getElementById('programs-menu-btn');
      const dropdown = document.getElementById('programs-dropdown');
      let populated = false;

      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        if (!expanded) {
          if (!populated) {
            programs.forEach((p) => {
              const a = document.createElement('a');
              a.href = '/' + p.slug;
              a.className = 'block px-3 py-2 rounded hover:bg-blood/5';
              a.textContent = p.shortName;
              dropdown.appendChild(a);
            });
            populated = true;
          }
          dropdown.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
        } else {
          dropdown.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
        }
      });

      document.addEventListener('click', (e) => {
        if (!document.getElementById('programs-menu').contains(e.target)) {
          dropdown.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    </script>

    <a href={ctaHref} class="btn-primary text-xs sm:text-sm">First class is FREE →</a>
  </div>
</header>
