---
import { Image } from 'astro:assets';
import hero from '@/assets/photos/gym-hero.jpg';
import logo from '@/assets/brand/the-lc-logo.png';
import { site } from '@/data/site';
---

<section class="relative bg-iron text-paper overflow-hidden">
  <div class="absolute inset-0">
    <Image src={hero} alt="The LC gym" class="w-full h-full object-cover opacity-25" loading="eager" fetchpriority="high" />
    <div class="absolute inset-0 bg-gradient-to-br from-iron via-iron/85 to-iron/55"></div>
  </div>
  <div class="relative container-page py-20 md:py-28 max-w-3xl">
    <p class="text-[11px] uppercase tracking-eyebrow text-blood font-bold">Walnut Ridge, AR · Inside K1 Fitness</p>
    <Image src={logo} alt="The LC" class="mt-6 w-72 md:w-96 h-auto drop-shadow-xl" loading="eager" fetchpriority="high" />
    <h1 class="mt-8 font-display text-3xl md:text-4xl leading-tight">
      Real training. <span class="text-blood">Real people.</span>
    </h1>
    <p class="mt-4 max-w-prose text-paper/80 text-base">
      {site.tagline}
    </p>
    <div class="mt-7 flex flex-wrap gap-3">
      <a class="btn-primary text-base" href="#schedule">First class is FREE →</a>
      <a class="border border-paper text-paper font-bold text-sm rounded-md px-4 py-3 hover:bg-paper hover:text-iron transition-colors" href="#programs">What we offer</a>
    </div>
  </div>
</section>
